### 📄 `utils/functional.go` (Funciones puras reutilizables)

```go
package utils

import (
	"encoding/json"
	"os"
)

// === FUNCIONES PURAS (Sin side-effects) ===

// FilterBy: Filtra un slice usando una función predicado (Higher-Order Function)
// Aplica concepto de Unidad 1: slices como vistas dinámicas de arrays
func FilterBy[T any](items []T, predicate func(T) bool) []T {
	result := make([]T, 0)
	for _, item := range items {
		if predicate(item) {
			result = append(result, item)
		}
	}
	return result // Retorna nuevo slice, no modifica el original (inmutabilidad)
}

// MapTransform: Transforma cada elemento de un slice (Higher-Order Function)
func MapTransform[T, U any](items []T, transform func(T) U) []U {
	result := make([]U, len(items))
	for i, item := range items {
		result[i] = transform(item)
	}
	return result
}

// Reduce: Aplica operación acumulativa (concepto matemático de Unidad 1)
// Ejemplo: calcular total del carrito
func Reduce[T, U any](items []T, initial U, accumulator func(U, T) U) U {
	result := initial
	for _, item := range items {
		result = accumulator(result, item)
	}
	return result
}

// === Funciones de I/O (Side-effects controlados en capa externa) ===

// LoadJSON: Carga datos desde archivo JSON a un slice/map
func LoadJSON[T any](filename string, target *T) error {
	file, err := os.Open(filename)
	if err != nil {
		return err
	}
	defer file.Close()
	
	decoder := json.NewDecoder(file)
	return decoder.Decode(target)
}

// SaveJSON: Guarda datos a archivo JSON
func SaveJSON[T any](filename string, data T) error {
	file, err := os.Create(filename)
	if err != nil {
		return err
	}
	defer file.Close()
	
	encoder := json.NewEncoder(file)
	encoder.SetIndent("", "  ")
	return encoder.Encode(data)
}
